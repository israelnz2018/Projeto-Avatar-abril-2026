rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - ownerUid: string (required)
    //   - ownerEmail: string (optional)
    //   - currentPhase: string (required)
    //   - createdAt: timestamp (required)
    //   - completedTools: list (optional)
    //
    // Collection: projects/{projectId}/data
    // Document ID: toolType
    // Fields:
    //   - toolType: string (required)
    //   - content: map (required)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "israelnz2018@hotmail.com" || 
        request.auth.token.email == "israel@learningbyworking.com"
      );
    }

    // Global Admin Override: The owner can do ANYTHING
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isProjectOwner(projectId) {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/projects/$(projectId)).data.ownerUid == request.auth.uid
      );
    }

    // Projects
    match /projects/{projectId} {
      // Allow read if user is owner or admin
      allow read: if isAuthenticated() && (isAdmin() || resource == null || resource.data.ownerUid == request.auth.uid);
      
      // Allow create if authenticated and setting self as owner
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      
      // Allow update/delete if owner or admin
      allow update, delete: if isAuthenticated() && (isAdmin() || resource.data.ownerUid == request.auth.uid);
      
      // Subcollection: data
      match /data/{dataId} {
        allow read, write: if isProjectOwner(projectId) || isAdmin();
      }
    }

    // Initiatives and Configs
    match /initiatives/{initiativeId} {
      allow read, write: if true;
    }

    match /initiative_configs/{configId} {
      allow read, write: if true;
    }

    // Other collections (Publicly readable by authenticated users for now)
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /playlists/{playlistId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /knowledge_base/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Test collection for connection testing
    match /test/{docId} {
      allow read: if true;
    }
  }
}
